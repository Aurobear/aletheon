# Build from GBrain v0.42.59.0 commit 5008b287e47bf791132eedfebf66bdef11e9398c.
# The tag is local; do not substitute an unpinned `latest` image.
GBRAIN_IMAGE=gbrain:5008b287e47bf791132eedfebf66bdef11e9398c
GBRAIN_BIND_ADDRESS=127.0.0.1
GBRAIN_PORT=9020
GBRAIN_CPU_LIMIT=2.0
GBRAIN_MEMORY_LIMIT=2G
GBRAIN_MEMORY_RESERVATION=256M

# Create these files locally with mode 0600. Never commit their contents.
GBRAIN_READ_TOKEN_FILE=./secrets/read-token
GBRAIN_WRITE_TOKEN_FILE=./secrets/write-token
