# Production overlay. Copy to /etc/aletheon/config.toml as root (0640,
# root:aletheon). Secret fields are file references only; never put values here.

[agent]
default_provider = "leju"
default_model = "deepseek/deepseek-v4-pro"

# The service loads LEJU_API_KEY from deployment.secrets.provider through its
# EnvironmentFile. Keep the credential out of this checked-in configuration.
[[providers]]
name = "leju"
base_url = "https://aiapi.lejurobot.com"
api_key = ""
transport = "openai"
models = ["deepseek/deepseek-v4-pro"]

[memory]
backend = "sqlite"
data_dir = "/var/lib/aletheon/mnemosyne"

[memory.gbrain]
enabled = false
projection_enabled = false
spool_path = "/var/lib/aletheon/mnemosyne/gbrain-spool.db"
legacy_outbox_dir = "/var/lib/aletheon/mnemosyne/gbrain-outbox"

[daemon]
socket_path = "/run/aletheon/aletheon.sock"
log_level = "info"

[pi_runtime]
enabled = false
worktree_base = "/var/lib/aletheon/worktrees"

[deployment]
mode = "production"

[deployment.paths]
state_root = "/var/lib/aletheon"
config_root = "/etc/aletheon"
runtime_root = "/run/aletheon"
cache_root = "/var/cache/aletheon"
state = "/var/lib/aletheon/state"
goals = "/var/lib/aletheon/goals"
sessions = "/var/lib/aletheon/sessions"
mnemosyne = "/var/lib/aletheon/mnemosyne"
artifacts = "/var/lib/aletheon/artifacts"
worktrees = "/var/lib/aletheon/worktrees"
audit = "/var/lib/aletheon/audit"
secret_root = "/etc/aletheon/credentials"

[deployment.quotas]
total_data_bytes = 107374182400
total_data_soft_bytes = 91268055040
total_data_items = 2000000
minimum_free_bytes = 5368709120
artifacts_bytes = 21474836480
artifacts_soft_bytes = 17179869184
artifacts_items = 100000
worktrees_bytes = 42949672960
worktrees_soft_bytes = 34359738368
worktrees_items = 10000
audit_bytes = 5368709120
audit_soft_bytes = 4294967296
audit_items = 400000
sessions_bytes = 10737418240
sessions_soft_bytes = 8589934592
sessions_items = 500000
google_bytes = 5368709120
google_soft_bytes = 4294967296
google_items = 500000
gbrain_spool_bytes = 268435456
gbrain_spool_soft_bytes = 201326592
gbrain_spool_items = 10000

[deployment.integrations]
telegram = false
google = false
gbrain = false

[deployment.secrets]
provider = "/etc/aletheon/credentials/provider.env"
telegram = "/etc/aletheon/credentials/telegram.env"
google_vault_key = "/etc/aletheon/credentials/google-vault.key"
gbrain = "/etc/aletheon/credentials/gbrain.env"
backup_password = "/etc/aletheon/credentials/restic-password"

[deployment.backup]
mode = "encrypted_remote"
repository_file = "/etc/aletheon/credentials/restic-repository"

[deployment.health]
minimum_free_bytes = 5368709120
maximum_backup_age_secs = 129600
maximum_sync_lag_secs = 3600

# To enable Google, set deployment.integrations.google=true and provide these
# non-secret values. Public OAuth clients do not require client_secret.
[integrations.google]
client_type = "public"
# client_id = "...apps.googleusercontent.com"
# redirect_uri = "http://127.0.0.1:8080/oauth/callback"
# client_secret = { env = "ALETHEON_GOOGLE_CLIENT_SECRET" }
drive_sync_enabled = false
drive_file_ids = []

# Search is independently optional. Enabling it makes both api_url and api_key
# mandatory during startup preflight.
[integrations.search]
enabled = false
# api_url = "https://search.example.invalid/v1/search"
# api_key = { env = "ALETHEON_SEARCH_API_KEY" }
